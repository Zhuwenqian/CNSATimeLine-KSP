<?xml version="1.0" encoding="utf-8"?>
<!--
  文件用途：
  本文件是 CNSATimeLine 模组的 MSBuild 项目文件，用于定义目标框架、输出类型、引用程序集以及编译行为。
  项目面向 .NET Framework 4.7.2，引用 KSP 1.12.5 游戏程序集以及 RSSTimeFormatter.dll。

  可调参数：
  - TargetFrameworkVersion：目标 .NET Framework 版本，默认 4.7.2。若 KSP 版本变更，可同步调整。
  - OutputPath：编译输出目录，默认 bin\$(Configuration)\，保持相对路径以兼容跨平台构建。
  - KSPDllPath：KSP 游戏程序集目录，默认 $(MSBuildProjectDirectory)\KSP DLL，使用相对路径。
-->
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <PropertyGroup>
    <!-- 项目基础配置 -->
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>CNSATimeLine</RootNamespace>
    <AssemblyName>CNSATimeLine</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>

    <!-- KSP 程序集目录，使用相对路径以支持跨平台 -->
    <KSPDllPath>$(MSBuildProjectDirectory)\KSP DLL</KSPDllPath>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <ItemGroup>
    <!-- KSP 核心程序集引用 -->
    <Reference Include="Assembly-CSharp">
      <HintPath>$(KSPDllPath)\Assembly-CSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Assembly-CSharp-firstpass">
      <HintPath>$(KSPDllPath)\Assembly-CSharp-firstpass.dll</HintPath>
      <Private>false</Private>
    </Reference>

    <!-- Unity 引擎核心模块引用 -->
    <Reference Include="UnityEngine">
      <HintPath>$(KSPDllPath)\UnityEngine.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(KSPDllPath)\UnityEngine.CoreModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.IMGUIModule">
      <HintPath>$(KSPDllPath)\UnityEngine.IMGUIModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.UI">
      <HintPath>$(KSPDllPath)\UnityEngine.UI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.UIElementsModule">
      <HintPath>$(KSPDllPath)\UnityEngine.UIElementsModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.UIModule">
      <HintPath>$(KSPDllPath)\UnityEngine.UIModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.InputLegacyModule">
      <HintPath>$(KSPDllPath)\UnityEngine.InputLegacyModule.dll</HintPath>
      <Private>false</Private>
    </Reference>

    <!-- 系统程序集引用 -->
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Xml" />

    <!-- 模组自定义依赖：时间格式化库 -->
    <Reference Include="RSSTimeFormatter">
      <HintPath>$(MSBuildProjectDirectory)\RSSTimeFormatter.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Compile Include="CNSATimeLineMod.cs" />
    <Compile Include="TimeLineEvent.cs" />
    <Compile Include="TimeLineConverter.cs" />
    <Compile Include="TimeLineDataLoader.cs" />
    <Compile Include="TimeLineWindow.cs" />
  </ItemGroup>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
